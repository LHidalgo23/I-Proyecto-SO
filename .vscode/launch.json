{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Terminal",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/terminal",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "preLaunchTask": "build",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
]
}